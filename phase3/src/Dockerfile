FROM node:18 AS build
WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

ARG REACT_APP_API_PROCESS_LOGIN
ARG REACT_APP_API_PROCESS_LOGIN_GG
ARG REACT_APP_API_NOTES
ARG REACT_APP_API_ADD_NOTE
ARG REACT_APP_API_DELETE_NOTE
ARG REACT_APP_API_UPDATE_NOTE
ARG REACT_APP_API_IMAGE_UPLOAD

ENV REACT_APP_API_PROCESS_LOGIN=$REACT_APP_API_PROCESS_LOGIN
ENV REACT_APP_API_PROCESS_LOGIN_GG=$REACT_APP_API_PROCESS_LOGIN_GG
ENV REACT_APP_API_NOTES=$REACT_APP_API_NOTES
ENV REACT_APP_API_ADD_NOTE=$REACT_APP_API_ADD_NOTE
ENV REACT_APP_API_DELETE_NOTE=$REACT_APP_API_DELETE_NOTE
ENV REACT_APP_API_UPDATE_NOTE=$REACT_APP_API_UPDATE_NOTE
ENV REACT_APP_API_IMAGE_UPLOAD=$REACT_APP_API_IMAGE_UPLOAD

RUN npm run build

